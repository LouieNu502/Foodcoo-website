<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Anderson Family — Food COO Portal</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --cream:       #F7F3EC;
  --warm-white:  #FDFCF9;
  --brown-deep:  #231810;
  --brown-mid:   #5A3825;
  --brown-light: #8C6649;
  --taupe:       #B8A898;
  --sand:        #D8C9B0;
  --sage:        #6B8A62;
  --sage-soft:   #C8D8C2;
  --terra:       #C46A42;
  --terra-soft:  #EDD5C4;
  --gold:        #C9A254;
  --gold-soft:   #F0E0B8;
  --ink:         #1A1208;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }

body {
background: var(–cream);
color: var(–brown-deep);
font-family: ‘DM Sans’, sans-serif;
font-weight: 300;
min-height: 100vh;
}

/* ───── TOP BAR ───── */
.topbar {
background: var(–brown-deep);
padding: 0 48px;
height: 56px;
display: flex; align-items: center; justify-content: space-between;
position: sticky; top: 0; z-index: 200;
}
.topbar-brand {
font-family: ‘Playfair Display’, serif;
font-size: 0.95rem;
color: var(–cream);
display: flex; align-items: center; gap: 10px;
}
.topbar-brand span { color: var(–gold); font-style: italic; }
.topbar-divider { width: 1px; height: 18px; background: rgba(255,255,255,0.15); }
.topbar-family {
font-size: 0.72rem;
letter-spacing: 0.14em;
text-transform: uppercase;
color: var(–taupe);
}
.topbar-right { display: flex; align-items: center; gap: 20px; }
.topbar-week {
background: var(–terra);
color: white;
font-size: 0.68rem;
letter-spacing: 0.12em;
text-transform: uppercase;
padding: 5px 14px;
border-radius: 100px;
}
.topbar-erin {
display: flex; align-items: center; gap: 8px;
font-size: 0.78rem; color: var(–taupe);
}
.erin-dot {
width: 8px; height: 8px;
background: var(–sage);
border-radius: 50%;
box-shadow: 0 0 0 3px rgba(107,138,98,0.25);
animation: pulse 2s infinite;
}
@keyframes pulse {
0%,100% { box-shadow: 0 0 0 3px rgba(107,138,98,0.25); }
50%      { box-shadow: 0 0 0 6px rgba(107,138,98,0.1); }
}

/* ───── HERO BANNER ───── */
.hero-banner {
background: linear-gradient(120deg, var(–brown-mid) 0%, var(–brown-deep) 60%);
padding: 52px 48px 0;
display: grid;
grid-template-columns: 1fr auto;
gap: 40px;
align-items: end;
overflow: hidden;
position: relative;
}
.hero-banner::before {
content: ‘’;
position: absolute; inset: 0;
background:
radial-gradient(ellipse at 80% 0%, rgba(201,162,84,0.12) 0%, transparent 55%),
radial-gradient(ellipse at 10% 100%, rgba(196,106,66,0.1) 0%, transparent 45%);
pointer-events: none;
}
.hero-banner-text { position: relative; z-index: 1; padding-bottom: 48px; }
.banner-greeting {
font-size: 0.7rem;
letter-spacing: 0.22em;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 16px;
display: flex; align-items: center; gap: 10px;
}
.banner-greeting::before { content:’’; width:28px; height:1px; background:var(–gold); display:block; }
.banner-h1 {
font-family: ‘Playfair Display’, serif;
font-size: clamp(2.4rem, 4vw, 3.8rem);
font-weight: 900;
color: var(–cream);
line-height: 1.05;
margin-bottom: 8px;
}
.banner-h1 em { color: var(–gold); font-style: italic; }
.banner-sub {
font-family: ‘Lora’, serif;
font-size: 1.05rem;
font-style: italic;
color: rgba(247,243,236,0.65);
margin-top: 14px;
max-width: 480px;
line-height: 1.7;
}
.banner-tags { display:flex; gap:8px; margin-top:20px; flex-wrap:wrap; }
.banner-tag {
border: 1px solid rgba(255,255,255,0.2);
color: rgba(247,243,236,0.7);
font-size: 0.68rem;
letter-spacing: 0.1em;
text-transform: uppercase;
padding: 5px 12px;
border-radius: 100px;
}
.banner-tag.active { border-color: var(–gold); color: var(–gold); background: rgba(201,162,84,0.1); }

/* ── Progress cards strip ── */
.banner-cards {
display: flex; gap: 2px;
align-self: end;
position: relative; z-index: 1;
}
.bcard {
background: rgba(255,255,255,0.06);
border: 1px solid rgba(255,255,255,0.1);
border-bottom: none;
padding: 20px 24px;
min-width: 120px;
text-align: center;
border-radius: 3px 3px 0 0;
}
.bcard-num {
font-family: ‘Playfair Display’, serif;
font-size: 2rem; font-weight: 900;
color: var(–gold);
display: block; line-height: 1;
}
.bcard-label {
font-size: 0.62rem; letter-spacing: 0.14em;
text-transform: uppercase; color: var(–taupe);
margin-top: 4px; display: block;
}

/* ───── MAIN GRID ───── */
.main-grid {
display: grid;
grid-template-columns: 1fr 380px;
gap: 0;
min-height: calc(100vh - 56px - 180px);
}

/* ───── LEFT PANEL ───── */
.left-panel {
padding: 40px 48px;
border-right: 1px solid var(–sand);
}

/* ── Section labels ── */
.slabel {
font-size: 0.65rem;
letter-spacing: 0.22em;
text-transform: uppercase;
color: var(–terra);
font-weight: 500;
display: flex; align-items: center; gap: 10px;
margin-bottom: 20px;
}
.slabel::before { content:’’; width:22px; height:1px; background:var(–terra); display:block; }

/* ── Meal Plan Week ── */
.meal-week {
display: grid;
grid-template-columns: repeat(7, 1fr);
gap: 6px;
margin-bottom: 40px;
}
.meal-cell {
background: var(–warm-white);
border: 1.5px solid var(–sand);
border-radius: 6px;
padding: 14px 8px 12px;
text-align: center;
cursor: pointer;
transition: all 0.2s;
position: relative;
}
.meal-cell:hover {
border-color: var(–brown-light);
transform: translateY(-3px);
box-shadow: 0 6px 20px rgba(44,31,20,0.1);
}
.meal-cell.today {
border-color: var(–terra);
background: var(–terra-soft);
}
.meal-cell.today::after {
content: ‘TODAY’;
position: absolute; bottom: -10px; left: 50%; transform: translateX(-50%);
font-size: 0.5rem; letter-spacing: 0.12em;
background: var(–terra); color: white;
padding: 2px 7px; border-radius: 100px;
}
.meal-cell.completed { opacity: 0.55; }
.meal-day-abbr {
font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase;
color: var(–taupe); margin-bottom: 8px;
}
.meal-emoji { font-size: 1.5rem; margin-bottom: 6px; display: block; }
.meal-name {
font-size: 0.7rem; color: var(–brown-mid); line-height: 1.35; font-weight: 400;
}
.meal-type {
font-size: 0.58rem; color: var(–taupe); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.08em;
}

/* ── Meal Detail Drawer ── */
.meal-drawer {
background: var(–warm-white);
border: 1px solid var(–sand);
border-radius: 6px;
padding: 28px;
margin-bottom: 40px;
display: none;
animation: slideDown 0.25s ease;
}
.meal-drawer.open { display: block; }
@keyframes slideDown {
from { opacity:0; transform:translateY(-8px); }
to   { opacity:1; transform:translateY(0); }
}
.drawer-header {
display: flex; justify-content: space-between; align-items: flex-start;
margin-bottom: 16px;
}
.drawer-title {
font-family: ‘Playfair Display’, serif;
font-size: 1.3rem; color: var(–brown-deep);
}
.drawer-close {
background: none; border: none; cursor: pointer;
font-size: 1.2rem; color: var(–taupe); line-height: 1;
}
.drawer-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
.drawer-stat { }
.drawer-stat-label {
font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase;
color: var(–taupe); margin-bottom: 4px;
}
.drawer-stat-val { font-size: 0.9rem; color: var(–brown-deep); font-weight: 400; }
.drawer-note {
margin-top: 14px; padding: 12px 16px;
background: var(–gold-soft);
border-left: 3px solid var(–gold);
font-size: 0.82rem; color: var(–brown-mid); line-height: 1.6;
border-radius: 0 4px 4px 0;
}
.drawer-note strong { color: var(–brown-deep); }

/* ── Prep Notes ── */
.prep-section { margin-bottom: 40px; }
.prep-card {
background: var(–brown-deep);
border-radius: 6px;
padding: 28px 32px;
color: var(–cream);
display: grid;
grid-template-columns: 1fr 1fr;
gap: 24px;
}
.prep-col-title {
font-size: 0.65rem; letter-spacing: 0.16em; text-transform: uppercase;
color: var(–gold); margin-bottom: 14px; font-weight: 500;
}
.prep-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.prep-list li {
display: flex; align-items: flex-start; gap: 10px;
font-size: 0.82rem; color: rgba(247,243,236,0.8); line-height: 1.5;
}
.prep-list li::before { content:’—’; color: var(–terra); flex-shrink: 0; }

/* ── Feedback Form ── */
.feedback-section { margin-bottom: 40px; }
.feedback-cards { display: flex; flex-direction: column; gap: 12px; }
.fb-card {
background: var(–warm-white);
border: 1.5px solid var(–sand);
border-radius: 6px;
padding: 20px 22px;
transition: border-color 0.2s;
}
.fb-card:hover { border-color: var(–taupe); }
.fb-meal-name {
font-family: ‘Playfair Display’, serif;
font-size: 1rem; color: var(–brown-deep);
margin-bottom: 10px;
}
.fb-stars { display: flex; gap: 4px; margin-bottom: 10px; }
.fb-star {
font-size: 1.3rem; cursor: pointer;
color: var(–sand); transition: color 0.15s;
}
.fb-star.lit { color: var(–gold); }
.fb-input {
width: 100%;
background: var(–cream);
border: 1px solid var(–sand);
border-radius: 3px;
padding: 10px 14px;
font-family: ‘DM Sans’, sans-serif;
font-size: 0.82rem;
color: var(–brown-deep);
resize: none;
outline: none;
transition: border-color 0.2s;
}
.fb-input:focus { border-color: var(–terra); }
.fb-submit {
margin-top: 8px;
background: none;
border: 1.5px solid var(–sand);
padding: 8px 20px;
font-family: ‘DM Sans’, sans-serif;
font-size: 0.72rem;
letter-spacing: 0.1em;
text-transform: uppercase;
color: var(–brown-mid);
cursor: pointer;
border-radius: 2px;
transition: all 0.2s;
}
.fb-submit:hover { border-color: var(–terra); color: var(–terra); }
.fb-sent {
font-size: 0.78rem; color: var(–sage);
display: none; margin-top: 8px;
}

/* ── Google Form Embed Zone ── */
.gform-zone {
background: var(–warm-white);
border: 2px dashed var(–sand);
border-radius: 6px;
padding: 36px;
text-align: center;
margin-bottom: 40px;
}
.gform-icon { font-size: 2rem; margin-bottom: 10px; }
.gform-title {
font-family: ‘Playfair Display’, serif;
font-size: 1.1rem; color: var(–brown-deep); margin-bottom: 6px;
}
.gform-desc { font-size: 0.82rem; color: var(–taupe); line-height: 1.6; margin-bottom: 16px; }
.gform-placeholder {
background: var(–cream);
border: 1px solid var(–sand);
border-radius: 4px;
padding: 12px 16px;
font-size: 0.72rem;
letter-spacing: 0.1em;
color: var(–taupe);
text-transform: uppercase;
font-family: ‘DM Sans’, monospace;
}

/* ───── RIGHT PANEL ───── */
.right-panel {
padding: 40px 32px;
background: var(–warm-white);
display: flex; flex-direction: column; gap: 32px;
}

/* ── Erin’s Note ── */
.erins-note {
background: var(–brown-deep);
border-radius: 6px;
padding: 28px;
color: var(–cream);
position: relative;
overflow: hidden;
}
.erins-note::before {
content: ‘”’;
font-family: ‘Playfair Display’, serif;
font-size: 7rem;
position: absolute; top: -10px; right: 16px;
color: rgba(201,162,84,0.15);
font-style: italic;
line-height: 1;
}
.note-from {
font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase;
color: var(–gold); margin-bottom: 14px;
display: flex; align-items: center; gap: 8px;
}
.note-from::before { content:’’; width:18px; height:1px; background:var(–gold); }
.note-text {
font-family: ‘Lora’, serif;
font-size: 0.95rem;
font-style: italic;
line-height: 1.75;
color: rgba(247,243,236,0.88);
position: relative; z-index: 1;
}
.note-date {
margin-top: 16px;
font-size: 0.68rem; color: var(–taupe);
letter-spacing: 0.08em;
}

/* ── Profile Summary ── */
.profile-card {
background: var(–cream);
border: 1px solid var(–sand);
border-radius: 6px;
padding: 24px;
}
.profile-title {
font-family: ‘Playfair Display’, serif;
font-size: 1rem; color: var(–brown-deep);
margin-bottom: 16px;
}
.profile-row {
display: flex; justify-content: space-between;
padding: 8px 0;
border-bottom: 1px solid var(–sand);
font-size: 0.8rem;
}
.profile-row:last-child { border-bottom: none; }
.profile-key { color: var(–taupe); font-size: 0.72rem; letter-spacing: 0.06em; text-transform: uppercase; }
.profile-val { color: var(–brown-deep); font-weight: 400; text-align: right; max-width: 55%; }
.profile-tags { display: flex; flex-wrap: wrap; gap: 4px; justify-content: flex-end; }
.ptag {
font-size: 0.65rem;
padding: 3px 9px;
border-radius: 100px;
border: 1px solid var(–terra);
color: var(–terra);
white-space: nowrap;
}
.ptag.green { border-color: var(–sage); color: var(–sage); }

/* ── Grocery Panel ── */
.grocery-panel {
background: var(–cream);
border: 1px solid var(–sand);
border-radius: 6px;
padding: 24px;
}
.grocery-title {
font-family: ‘Playfair Display’, serif;
font-size: 1rem; color: var(–brown-deep);
margin-bottom: 6px;
}
.grocery-sub { font-size: 0.78rem; color: var(–taupe); margin-bottom: 18px; line-height: 1.5; }
.grocery-services { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
.grocery-btn {
display: flex; align-items: center; justify-content: space-between;
padding: 12px 16px;
background: var(–warm-white);
border: 1.5px solid var(–sand);
border-radius: 4px;
cursor: pointer;
transition: all 0.2s;
text-decoration: none;
}
.grocery-btn:hover { border-color: var(–terra); transform: translateX(3px); }
.grocery-btn.preferred { border-color: var(–sage); background: var(–sage-soft); }
.grocery-btn-left { display: flex; align-items: center; gap: 10px; }
.grocery-btn-icon { font-size: 1.1rem; }
.grocery-btn-name { font-size: 0.82rem; color: var(–brown-deep); font-weight: 400; }
.grocery-btn-tag {
font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase;
color: var(–sage); font-weight: 500;
}
.grocery-btn-arrow { color: var(–taupe); font-size: 0.85rem; }
.grocery-note {
font-size: 0.72rem; color: var(–taupe); line-height: 1.5;
padding: 10px 14px;
background: var(–gold-soft);
border-radius: 3px;
}

/* ── Upcoming / Next Steps ── */
.next-card {
background: var(–terra);
border-radius: 6px;
padding: 24px;
color: white;
}
.next-title {
font-family: ‘Playfair Display’, serif;
font-size: 0.95rem; margin-bottom: 14px;
}
.next-list { display: flex; flex-direction: column; gap: 10px; }
.next-item {
display: flex; align-items: center; gap: 10px;
font-size: 0.8rem; color: rgba(255,255,255,0.88);
}
.next-item-dot {
width: 6px; height: 6px; background: rgba(255,255,255,0.4); border-radius: 50%; flex-shrink: 0;
}
.next-item strong { color: white; display: block; font-weight: 500; }

/* ── History toggle ── */
.history-section { margin-bottom: 40px; }
.history-toggle {
display: flex; align-items: center; justify-content: space-between;
cursor: pointer; padding: 14px 0; border-bottom: 1px solid var(–sand);
margin-bottom: 0;
}
.history-toggle-label {
font-size: 0.8rem; color: var(–brown-mid); letter-spacing: 0.06em;
}
.history-toggle-arrow { color: var(–taupe); font-size: 0.8rem; transition: transform 0.2s; }
.history-toggle-arrow.open { transform: rotate(180deg); }
.history-list {
display: none; flex-direction: column; gap: 0;
}
.history-list.open { display: flex; }
.history-item {
display: flex; align-items: center; justify-content: space-between;
padding: 12px 0; border-bottom: 1px solid rgba(216,201,176,0.4);
font-size: 0.82rem;
}
.history-item-meal { color: var(–brown-deep); }
.history-item-date { color: var(–taupe); font-size: 0.72rem; }
.history-item-stars { color: var(–gold); font-size: 0.75rem; letter-spacing: 2px; }

/* ───── FOOTER ───── */
.portal-footer {
background: var(–brown-deep);
padding: 24px 48px;
display: flex; align-items: center; justify-content: space-between;
}
.footer-left {
font-family: ‘Playfair Display’, serif;
font-size: 0.9rem; color: var(–cream);
}
.footer-left span { color: var(–gold); font-style: italic; }
.footer-right { font-size: 0.72rem; color: var(–taupe); text-align: right; line-height: 1.7; }

/* ───── EDIT MODAL ───── */
.modal-bg {
position: fixed; inset: 0;
background: rgba(26,18,8,0.7);
backdrop-filter: blur(6px);
z-index: 500;
display: flex; align-items: center; justify-content: center;
opacity: 0; pointer-events: none;
transition: opacity 0.3s;
}
.modal-bg.show { opacity: 1; pointer-events: all; }
.modal-box {
background: var(–cream);
border-radius: 8px;
padding: 44px;
max-width: 500px; width: 90%;
max-height: 88vh; overflow-y: auto;
transform: translateY(18px); transition: transform 0.3s;
box-shadow: 0 40px 80px rgba(26,18,8,0.35);
}
.modal-bg.show .modal-box { transform: translateY(0); }
.modal-x {
float: right; background: none; border: none; cursor: pointer;
font-size: 1.3rem; color: var(–taupe); line-height: 1;
}
.modal-x:hover { color: var(–brown-deep); }
.modal-h2 {
font-family: ‘Playfair Display’, serif;
font-size: 1.5rem; color: var(–brown-deep);
margin: 0 0 4px; clear: both;
}
.modal-sub { font-size: 0.82rem; color: var(–taupe); margin-bottom: 24px; line-height: 1.5; }
.mrow { margin-bottom: 18px; }
.mlabel {
display: block; font-size: 0.68rem; letter-spacing: 0.14em;
text-transform: uppercase; color: var(–brown-mid); margin-bottom: 7px; font-weight: 500;
}
.minput, .mselect, .mtextarea {
width: 100%;
padding: 11px 14px;
background: var(–warm-white);
border: 1.5px solid var(–sand);
border-radius: 3px;
font-family: ‘DM Sans’, sans-serif;
font-size: 0.85rem;
color: var(–brown-deep);
outline: none;
transition: border-color 0.2s;
}
.minput:focus, .mselect:focus, .mtextarea:focus { border-color: var(–terra); }
.mtextarea { resize: vertical; min-height: 80px; }
.mrow-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.chip-row { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 6px; }
.mchip {
padding: 6px 14px; border: 1.5px solid var(–sand);
border-radius: 100px; font-size: 0.75rem; cursor: pointer;
transition: all 0.2s; color: var(–brown-mid);
background: var(–warm-white); user-select: none;
}
.mchip:hover { border-color: var(–terra); color: var(–terra); }
.mchip.on { background: var(–terra); border-color: var(–terra); color: white; }
.mbtn {
width: 100%; background: var(–brown-deep); color: var(–cream);
border: none; padding: 15px; border-radius: 3px; cursor: pointer;
font-family: ‘DM Sans’, sans-serif; font-size: 0.78rem;
letter-spacing: 0.12em; text-transform: uppercase;
transition: background 0.2s; margin-top: 4px;
}
.mbtn:hover { background: var(–terra); }
.msuccess {
display: none; margin-top: 14px;
background: var(–sage-soft); border: 1px solid var(–sage);
border-radius: 3px; padding: 14px 18px;
font-size: 0.82rem; color: var(–brown-deep);
}
.msuccess.show { display: block; }

/* ── Edit name banner ── */
.edit-btn {
background: rgba(255,255,255,0.1);
border: 1px solid rgba(255,255,255,0.2);
color: rgba(247,243,236,0.7);
font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase;
padding: 6px 14px; border-radius: 100px;
cursor: pointer; transition: all 0.2s;
font-family: ‘DM Sans’, sans-serif;
}
.edit-btn:hover { background: rgba(255,255,255,0.18); color: var(–cream); }

/* ─── RESPONSIVE ─── */
@media(max-width:900px){
.topbar { padding: 0 20px; }
.hero-banner { padding: 36px 20px 0; grid-template-columns: 1fr; }
.banner-cards { display: none; }
.main-grid { grid-template-columns: 1fr; }
.left-panel { padding: 28px 20px; }
.right-panel { padding: 28px 20px; }
.meal-week { grid-template-columns: repeat(7,1fr); gap:3px; }
