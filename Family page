<script>
// ── Meal Drawer ──
function openDrawer(day, title, cuisine, time, serves, note) {
  document.getElementById('drawer-day').textContent = day;
  document.getElementById('drawer-title').textContent = title;
  document.getElementById('drawer-cuisine').textContent = cuisine;
  document.getElementById('drawer-time').textContent = time;
  document.getElementById('drawer-serves').textContent = serves;
  document.getElementById('drawer-note').textContent = note;
  const d = document.getElementById('meal-drawer');
  d.classList.add('open');
  d.scrollIntoView({ behavior:'smooth', block:'nearest' });
}
function closeDrawer() {
  document.getElementById('meal-drawer').classList.remove('open');
}

// ── Star ratings ──
function rateMeal(star, n) {
  const row = star.closest('.fb-stars');
  row.querySelectorAll('.fb-star').forEach((s,i) => s.classList.toggle('lit', i < n));
}

// ── Send feedback ──
function sendFeedback(btn) {
  const card = btn.closest('.fb-card');
  const msg = card.querySelector('.fb-sent');
  btn.style.display = 'none';
  msg.style.display = 'block';
}

// ── History toggle ──
function toggleHistory(el) {
  const list = el.nextElementSibling;
  const arrow = el.querySelector('.history-toggle-arrow');
  list.classList.toggle('open');
  arrow.classList.toggle('open');
}

// ── Modal ──
function openModal() {
  document.getElementById('edit-modal').classList.add('show');
  document.body.style.overflow = 'hidden';
}
function closeModal() {
  document.getElementById('edit-modal').classList.remove('show');
  document.body.style.overflow = '';
  document.getElementById('modal-success').classList.remove('show');
}
function closeModalOutside(e) {
  if (e.target === document.getElementById('edit-modal')) closeModal();
}

// ── Grocery single-select chips ──
function unchipSelect(chip) {
  chip.closest('.chip-row').querySelectorAll('.mchip').forEach(c => c.classList.remove('on'));
  chip.classList.add('on');
}

// ── Save profile ──
function saveProfile() {
  const name = document.getElementById('modal-family-input').value.trim();
  if (name) {
    const display = name.startsWith('The ') ? name : 'The ' + name;
    document.getElementById('family-name-topbar').textContent = display;
    document.getElementById('family-h1').innerHTML = `Welcome back, <em>${name.replace('The ','')}</em> 👋`;
    document.getElementById('profile-family-name').textContent = display;
  }
  document.getElementById('modal-success').classList.add('show');
  setTimeout(closeModal, 2800);
}

// ── Scroll reveal ──
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.style.opacity = '1';
      e.target.style.transform = 'translateY(0)';
    }
  });
}, { threshold: 0.08 });

document.querySelectorAll('.meal-cell, .fb-card, .prep-card, .profile-card, .erins-note, .grocery-panel, .next-card').forEach(el => {
  el.style.opacity = '0';
  el.style.transform = 'translateY(16px)';
  el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
  obs.observe(el);
});
</script>

